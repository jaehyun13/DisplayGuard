# Build artifacts
build/
dist/
Output/

# PyInstaller work files (but keep DisplayGuard.spec — it's part of the build pipeline)
*.spec
!DisplayGuard.spec

# Built executables (release binaries are attached to GitHub Releases, not committed)
*.exe

# User-generated runtime files
*.lnk
display_guard_config.json
display_guard.log

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Internal business/marketing drafts (not for public repo)
_business/

# License signing secrets — NEVER commit private keys
secrets/
*.pem
license_private*
*_private_*.key
